import cv2 # type: ignore
import mediapipe as mp
import numpy as np
from datetime import datetime
import threading
from collections import deque

class ErgonomicMonitor:
    def __init__(self):
        self.mp_pose = mp.solutions.pose
        self.mp_drawing = mp.solutions.drawing_utils
        self.pose = self.mp_pose.Pose(
            static_image_mode=False,
            model_complexity=1,
            smooth_landmarks=True
        )
        self.posture_history = deque(maxlen=30)
        self.alerts = []
        self.developer = "Developed by Mohamed Uwais"
        
    def calculate_distance(self, point1, point2):
        """Calculate Euclidean distance between two points"""
        return np.sqrt((point1[0] - point2[0])**2 + (point1[1] - point2[1])**2)
    
    def check_posture(self, landmarks, frame_width, frame_height):
        """Analyze posture based on body landmarks"""
        alerts = []
        
        # Get key points
        shoulder = landmarks[11].y
        ear = landmarks[8].y
        hip = landmarks[23].y
        
        # Check for forward head posture
        head_forward = ear > shoulder + 0.05
        if head_forward:
            alerts.append("⚠️ Forward Head Position Detected")
        
        # Check spine alignment
        spine_curve = abs(shoulder - hip) > 0.3
        if not spine_curve:
            alerts.append("⚠️ Poor Spine Alignment")
        
        # Check shoulder height (hunching)
        left_shoulder = landmarks[11]
        right_shoulder = landmarks[12]
        if left_shoulder.y > 0.5 and right_shoulder.y > 0.5:
            alerts.append("⚠️ Hunched Shoulders Detected")
        
        return alerts
    
    def add_watermark(self, frame):
        """Add developer watermark to frame"""
        font = cv2.FONT_HERSHEY_SIMPLEX
        font_scale = 0.5
        thickness = 1
        color = (200, 200, 200)
        
        # Add timestamp
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        cv2.putText(frame, timestamp, (10, 25), font, font_scale, color, thickness)
        
        # Add watermark
        cv2.putText(frame, self.developer, (10, frame.shape[0] - 10), font, 0.4, color, 1)
        
        return frame
    
    def run(self):
        """Main monitoring loop"""
        cap = cv2.VideoCapture(0)
        
        while cap.isOpened():
            ret, frame = cap.read()
            if not ret:
                break
            
            # Flip frame for selfie view
            frame = cv2.flip(frame, 1)
            h, w, c = frame.shape
            
            # Convert to RGB
            rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            results = self.pose.process(rgb_frame)
            
            # Draw pose
            if results.landmarks:
                self.mp_drawing.draw_landmarks(frame, results.landmarks, self.mp_pose.POSE_CONNECTIONS)
                
                # Check posture
                alerts = self.check_posture(results.landmarks, w, h)
                
                # Display alerts
                y_offset = 60
                for alert in alerts:
                    cv2.putText(frame, alert, (10, y_offset), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 0, 255), 2)
                    y_offset += 30
            
            # Add watermark
            frame = self.add_watermark(frame)
            
            # Display
            cv2.imshow('Ergonomic Posture Monitor', frame)
            
            if cv2.waitKey(5) & 0xFF == ord('q'):
                break
        
        cap.release()
        cv2.destroyAllWindows()

if __name__ == "__main__":
    monitor = ErgonomicMonitor()
    monitor.run()